rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "DKdSCSIlmZOZBRIrNymj13oOXxZ2" ||
        request.auth.token.email == "vivek5656sharma@gmail.com"
      );
    }

    // Default deny and admin access
    match /{document=**} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == "DKdSCSIlmZOZBRIrNymj13oOXxZ2" || 
        request.auth.token.email == "vivek5656sharma@gmail.com"
      );
    }
    
    // Explicit collection rules for non-admins
    match /packages/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == "DKdSCSIlmZOZBRIrNymj13oOXxZ2" || request.auth.token.email == "vivek5656sharma@gmail.com");
    }
    match /gallery/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == "DKdSCSIlmZOZBRIrNymj13oOXxZ2" || request.auth.token.email == "vivek5656sharma@gmail.com");
    }
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == "DKdSCSIlmZOZBRIrNymj13oOXxZ2" || request.auth.token.email == "vivek5656sharma@gmail.com");
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == "DKdSCSIlmZOZBRIrNymj13oOXxZ2" || request.auth.token.email == "vivek5656sharma@gmail.com");
    }
    match /inquiries/{docId} {
      allow create: if true;
      allow read, delete: if isSignedIn() && (request.auth.uid == "DKdSCSIlmZOZBRIrNymj13oOXxZ2" || request.auth.token.email == "vivek5656sharma@gmail.com");
    }
    match /bookings/{docId} {
      allow read, create: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || request.auth.token.email == "vivek5656sharma@gmail.com" || request.auth.uid == "DKdSCSIlmZOZBRIrNymj13oOXxZ2");
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || request.auth.token.email == "vivek5656sharma@gmail.com" || request.auth.uid == "DKdSCSIlmZOZBRIrNymj13oOXxZ2");
    }
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
