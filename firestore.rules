rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Top-level admin check by email
    function isEmailAdmin() {
      return request.auth != null && (
        request.auth.token.email == "vivek5656sharma@gmail.com" || 
        request.auth.token.email == "padatvivek2@gmail.com"
      );
    }

    // Role check from document. Only used if not email admin.
    function isDocAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isAdmin() {
      return isEmailAdmin() || isDocAdmin();
    }

    // Collection: Users
    match /users/{userId} {
      // Allow user to access their own doc or admins to access everything
      allow read, write: if request.auth != null && (request.auth.uid == userId || isEmailAdmin() || isDocAdmin());
    }

    // Collection: Packages, Gallery, Testimonials
    match /packages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection: Bookings
    match /bookings/{docId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Collection: Inquiries
    match /inquiries/{docId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
