rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Top-level admin check by email
    function isEmailAdmin() {
      return request.auth != null && (
        request.auth.token.email == "vivek5656sharma@gmail.com" || 
        request.auth.token.email == "padatvivek2@gmail.com"
      );
    }

    // Role check from document. Only used if not email admin.
    function isDocAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isAdmin() {
      return isEmailAdmin() || isDocAdmin();
    }

    // Check if user is logged in AND verified
    function isVerified() {
      return request.auth != null && (request.auth.token.email_verified == true || isEmailAdmin());
    }

    // Collection: Users
    match /users/{userId} {
      // Allow user to get their own doc, or admins to get any doc
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Allow admins to list users. We don't use "read" here to be explicit.
      allow list: if isAdmin();
      
      // Allow user to write their own doc, or admins to write/delete any doc
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Collection: Packages, Gallery, Testimonials
    match /packages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection: Settings
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    // Collection: Bookings
    match /bookings/{docId} {
      allow read: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && request.resource.data.userId == request.auth.uid;
      allow update: if isVerified() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid && 
         request.resource.data.status != "Completed" && 
         request.resource.data.status == resource.data.status)
      );
      allow delete: if isAdmin();
    }

    // Collection: Inquiries
    match /inquiries/{docId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
